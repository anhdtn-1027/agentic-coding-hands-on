# Auth.js v5 — generate a secret with: npx auth secret
AUTH_SECRET=your-auth-secret-here

# Google OAuth credentials (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Auth.js base URL (must match OAuth redirect URI in Google Console)
AUTH_URL=http://localhost:3000

# Comma-separated list of Google email addresses that receive the admin role
ADMIN_EMAILS=admin@example.com,another-admin@example.com

# SAA 2025 event datetime in ISO-8601 format (used for countdown)
# NEXT_PUBLIC_ prefix is required for client-side access via process.env.NEXT_PUBLIC_EVENT_DATETIME
NEXT_PUBLIC_EVENT_DATETIME=2025-12-31T18:30:00+07:00
